{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xprimeray.local/schemas/observer_storyboard_v1.schema.json",
  "title": "Observer Storyboard v1",
  "description": "Renderer-agnostic manifest for a nine-panel Observer Storyboard.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "title", "panels"],
  "properties": {
    "schema": {
      "const": "xprimeray.observer_storyboard.v1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "description": "Optional artifact-set identifier or path."
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "panels": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": { "$ref": "#/$defs/panel" }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "headline": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "status"],
            "properties": {
              "label": { "type": "string" },
              "status": { "$ref": "#/$defs/status" },
              "value": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "PARTIAL", "MISSING"]
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "key", "title", "question", "status"],
      "properties": {
        "slot": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9
        },
        "key": {
          "type": "string",
          "enum": [
            "observation",
            "assumptions",
            "perspectives",
            "disagreements",
            "closure_basin",
            "lineage",
            "coverage",
            "sensitivity_signature",
            "verdict"
          ]
        },
        "title": { "type": "string" },
        "question": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "artifact": {
          "type": "string",
          "description": "Optional image path relative to the manifest file or current working directory."
        },
        "caption": { "type": "string" },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        }
      }
    }
  }
}
