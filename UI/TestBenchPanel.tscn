[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://UI/TestBenchPanel.gd" id="1_gd"]
[ext_resource type="Script" path="res://UI/TestBenchController.cs" id="2_cs"]

[node name="TestBenchPanel" type="PanelContainer"]
custom_minimum_size = Vector2(980, 620)
script = ExtResource("1_gd")

[node name="Margin" type="MarginContainer" parent="."]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="Root" type="VBoxContainer" parent="Margin"]
theme_override_constants/separation = 10

[node name="Header" type="HBoxContainer" parent="Margin/Root"]
theme_override_constants/separation = 12

[node name="TitleLabel" type="Label" parent="Margin/Root/Header"]
size_flags_horizontal = 3
text = "xPRIMEray Test Bench"

[node name="StatusLabel" type="Label" parent="Margin/Root/Header"]
size_flags_horizontal = 3
horizontal_alignment = 2
text = "Ready."

[node name="Top" type="HBoxContainer" parent="Margin/Root"]
theme_override_constants/separation = 12

[node name="RecipeColumn" type="VBoxContainer" parent="Margin/Root/Top"]
custom_minimum_size = Vector2(340, 0)
size_flags_horizontal = 3
theme_override_constants/separation = 4

[node name="RecipeLabel" type="Label" parent="Margin/Root/Top/RecipeColumn"]
text = "Recipe"

[node name="RecipeOptions" type="OptionButton" parent="Margin/Root/Top/RecipeColumn"]
size_flags_horizontal = 3

[node name="ControlColumn" type="VBoxContainer" parent="Margin/Root/Top"]
custom_minimum_size = Vector2(300, 0)
size_flags_horizontal = 3
theme_override_constants/separation = 4

[node name="QualityLabel" type="Label" parent="Margin/Root/Top/ControlColumn"]
text = "Quality"

[node name="QualityOptions" type="OptionButton" parent="Margin/Root/Top/ControlColumn"]
size_flags_horizontal = 3

[node name="OverlayLabel" type="Label" parent="Margin/Root/Top/ControlColumn"]
text = "Overlay Mode"

[node name="OverlayOptions" type="OptionButton" parent="Margin/Root/Top/ControlColumn"]
size_flags_horizontal = 3

[node name="PlacementLabel" type="Label" parent="Margin/Root/Top/ControlColumn"]
text = "Overlay Placement"

[node name="PlacementOptions" type="OptionButton" parent="Margin/Root/Top/ControlColumn"]
size_flags_horizontal = 3

[node name="LegendColumn" type="VBoxContainer" parent="Margin/Root/Top"]
custom_minimum_size = Vector2(300, 0)
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="LegendTitle" type="Label" parent="Margin/Root/Top/LegendColumn"]
text = "Explanation Grammar"

[node name="LegendText" type="RichTextLabel" parent="Margin/Root/Top/LegendColumn"]
custom_minimum_size = Vector2(0, 132)
fit_content = true
bbcode_enabled = true
text = "[color=#d8d8d8]straight reference[/color] = white/gray
[color=#00d7ff]curved[/color]/[color=#ff4fd8]transport[/color] = cyan/magenta
[color=#2f7dff]density[/color] = blue
[color=#f2c14e]curvature[/color] = gold
[color=#ff9a2f]unresolved[/color]/[color=#ff4b2f]failed[/color] = orange/red
observer/camera = small labeled glyph
field center/nucleus = crosshair"

[node name="Actions" type="HBoxContainer" parent="Margin/Root"]
theme_override_constants/separation = 8

[node name="DryRunButton" type="Button" parent="Margin/Root/Actions"]
text = "Dry Run / Preview Command"

[node name="RunButton" type="Button" parent="Margin/Root/Actions"]
text = "Run"

[node name="AtomicQuickButton" type="Button" parent="Margin/Root/Actions"]
text = "Run Atomic quick_review density"

[node name="StopButton" type="Button" parent="Margin/Root/Actions"]
disabled = true
text = "Stop"

[node name="CopyButton" type="Button" parent="Margin/Root/Actions"]
text = "Copy Exact Command"

[node name="OpenFolderButton" type="Button" parent="Margin/Root/Actions"]
text = "Open in File Browser"

[node name="OpenReportButton" type="Button" parent="Margin/Root/Actions"]
text = "Open Report"

[node name="OpenContactButton" type="Button" parent="Margin/Root/Actions"]
text = "Open Latest Contact Sheet"

[node name="Body" type="HBoxContainer" parent="Margin/Root"]
size_flags_vertical = 3
theme_override_constants/separation = 10

[node name="InfoColumn" type="VBoxContainer" parent="Margin/Root/Body"]
custom_minimum_size = Vector2(300, 0)
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="GuardrailTitle" type="Label" parent="Margin/Root/Body/InfoColumn"]
text = "Recipe Guardrail"

[node name="GuardrailText" type="Label" parent="Margin/Root/Body/InfoColumn"]
autowrap_mode = 2
text = "Select a recipe."

[node name="CommandTitle" type="Label" parent="Margin/Root/Body/InfoColumn"]
text = "Exact Command"

[node name="CommandText" type="TextEdit" parent="Margin/Root/Body/InfoColumn"]
custom_minimum_size = Vector2(0, 180)
size_flags_horizontal = 3
size_flags_vertical = 3
editable = false
wrap_mode = 1

[node name="ArtifactColumn" type="VBoxContainer" parent="Margin/Root/Body"]
custom_minimum_size = Vector2(290, 0)
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="ArtifactTitle" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
text = "Latest Artifacts"

[node name="PreviewTitle" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
text = "Preview"

[node name="PreviewTexture" type="TextureRect" parent="Margin/Root/Body/ArtifactColumn"]
custom_minimum_size = Vector2(280, 160)
expand_mode = 1
stretch_mode = 5

[node name="FolderLabel" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
autowrap_mode = 2
text = "Folder:"

[node name="ReportLabel" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
autowrap_mode = 2
text = "Report:"

[node name="ContactLabel" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
autowrap_mode = 2
text = "Contact sheet:"

[node name="PreviewLabel" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
autowrap_mode = 2
text = "Preview:"

[node name="PlacementNote" type="Label" parent="Margin/Root/Body/ArtifactColumn"]
autowrap_mode = 2
text = "v1 overlay placement is descriptive. The Test Bench highlights existing artifacts/contact sheets; it does not inject live full-frame overlays into Godot."

[node name="LogColumn" type="VBoxContainer" parent="Margin/Root/Body"]
custom_minimum_size = Vector2(360, 0)
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="LogTitle" type="Label" parent="Margin/Root/Body/LogColumn"]
text = "Logs"

[node name="LogText" type="TextEdit" parent="Margin/Root/Body/LogColumn"]
size_flags_horizontal = 3
size_flags_vertical = 3
editable = false
wrap_mode = 1

[node name="TestBenchController" type="Node" parent="."]
script = ExtResource("2_cs")
