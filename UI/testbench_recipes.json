      "outputRoot": "output/atomic_orbital_grin_ladder",
      "rootEnv": "ATOMIC_ORBITAL_GRIN_ROOT",
      "qualityEnv": {
        "smoke": {
          "ATOMIC_ORBITAL_GRIN_SMOKE": "1"
        },
        "review": {
          "ATOMIC_ORBITAL_GRIN_SMOKE": "0"
        },
        "full": {
          "ATOMIC_ORBITAL_GRIN_SMOKE": "0"
        }
      },
      "allowedOverlayModes": [
        "none",
        "hit_miss_mask",
        "step_budget_heatmap",
        "domain_ownership_map"
      ],
      "allowedPlacements": [
        "none",
        "contact_sheet_only"
      ],
      "overlayEnv": {},
      "expectedReports": [
        "atomic_orbital_grin_ladder_report.md",
