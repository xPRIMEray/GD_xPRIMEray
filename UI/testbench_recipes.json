{
  "schema": "xprimeray.testbench.recipes.v1",
  "recipes": [
    {
      "id": "hermetic_closure_smoke",
      "title": "Hermetic Closure Smoke",
      "script": "scripts/run_hermetic_hit_closure_ladder.sh",
      "workingDirectory": ".",
      "testbenchWrappedOutput": false,
      "outputRoot": "output/hermetic_hit_closure",
      "rootEnv": "HERMETIC_CLOSURE_ROOT",
      "qualityEnv": {
        "smoke": {
          "HERMETIC_CLOSURE_SMOKE": "1"
        },
        "review": {
          "HERMETIC_CLOSURE_SMOKE": "0"
        },
        "full": {
          "HERMETIC_CLOSURE_SMOKE": "0"
        }
      },
      "allowedOverlayModes": [
        "none",
        "hit_miss_mask",
        "step_budget_heatmap",
        "domain_ownership_map"
      ],
      "allowedPlacements": [
        "none",
        "contact_sheet_only"
      ],
      "overlayEnv": {},
      "expectedReports": [
        "hermetic_hit_closure_summary.md",
        "hermetic_oracle_recommendations.md"
      ],
      "expectedContactSheets": [
        "hermetic_closure_ladder.png",
        "hermetic_failure_storyboard.png",
        "closure_recovery_storyboard.png"
      ],
      "expectedSummaries": [
        "hermetic_hit_closure_summary.json"
      ],
      "expectedPreviews": [
        "hermetic_hit_closure_heatmap.png",
        "adaptive_closure_recovery_heatmap.png"
      ],
      "guardrailText": "Validation recipe: pass/fail is owned by the script report. The Test Bench only launches the curated script and displays artifacts."
    },
    {
      "id": "atomic_grin_validation_smoke",
