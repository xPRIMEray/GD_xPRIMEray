      "guardrailText": "Validation recipe: pass/fail is owned by the script report. The Test Bench does not reinterpret closure, miss, or budget gates."
    },
    {
      "id": "atomic_visual_observatory",
      "title": "Atomic Orbital Visual Observatory",
      "script": "scripts/run_atomic_orbital_visual_observatory.sh",
      "workingDirectory": ".",
      "testbenchWrappedOutput": false,
      "outputRoot": "output/atomic_orbital_visual_observatory",
      "rootEnv": "ATOMIC_ORBITAL_VISUAL_ROOT",
      "qualityPresets": [
        "smoke",
        "quick_review",
        "review",
        "full"
      ],
      "defaultQuality": "quick_review",
      "qualityEnv": {
        "smoke": {
          "ATOMIC_ORBITAL_VISUAL_SMOKE": "1"
        },
        "quick_review": {
          "ATOMIC_ORBITAL_VISUAL_SMOKE": "0",
          "ATOMIC_ORBITAL_VISUAL_RES": "320x180",
          "ATOMIC_ORBITAL_VISUAL_FRAMES": "30",
          "ATOMIC_ORBITAL_VISUAL_WARMUP": "0",
          "ATOMIC_ORBITAL_VISUAL_UPDATE_BUDGET_MS": "2500",
          "ATOMIC_ORBITAL_VISUAL_BUDGET": "450",
          "ATOMIC_ORBITAL_VISUAL_STRIDE": "4",
          "ATOMIC_ORBITAL_VISUAL_CELLS": "V0_baseline_no_field,V2_exaggerated_hydrogen,V3_tick0,V4_tick1"
        },
        "review": {
          "ATOMIC_ORBITAL_VISUAL_SMOKE": "0"
        },
        "full": {
          "ATOMIC_ORBITAL_VISUAL_SMOKE": "0"
        }
      },
      "allowedOverlayModes": [
        "none",
        "density_contours",
        "curvature_contours"
      ],
      "allowedPlacements": [
        "none",
        "contact_sheet_only"
      ],
      "overlayEnv": {
        "density_contours": {
          "ATOMIC_ORBITAL_VISUAL_CONTOURS": "1",
          "ATOMIC_ORBITAL_VISUAL_CONTOUR_MODE": "density"
        },
        "curvature_contours": {
          "ATOMIC_ORBITAL_VISUAL_CONTOURS": "1",
          "ATOMIC_ORBITAL_VISUAL_CONTOUR_MODE": "curvature"
        }
      },
      "expectedReports": [
        "atomic_visual_observatory_report.md"
      ],
      "expectedContactSheets": [
        "atomic_visual_contact_sheet.png"
      ],
      "expectedSummaries": [
        "atomic_visual_diff_summary.json"
      ],
      "expectedPreviews": [
        "*__density_contours.png",
        "*__curvature_contours.png",
        "V0_vs_V1_scaled_diff.png",
        "V0_vs_V2_scaled_diff.png",
        "tick0_vs_tick1_scaled_diff.png"
      ],
      "guardrailText": "Interpretation only, not validation. Contours and visual overlays are postprocess guides derived from fixture metadata or saved captures."
    },
    {
      "id": "wormhole_structure_observatory",
      "title": "Wormhole Structure Observatory",
      "script": "scripts/run_wormhole_structure_observatory_quick.sh",
      "workingDirectory": ".",
      "scriptArgs": [
        "{timestamp}"
      ],
      "testbenchWrappedOutput": false,
      "outputRoot": "output/wormhole_structure_observatory",
      "rootEnv": "",
      "qualityPresets": [
        "quick_review",
        "review",
        "full"
      ],
      "defaultQuality": "quick_review",
      "qualityEnv": {
        "quick_review": {
          "WORMHOLE_STRUCTURE_QUALITY": "quick_review",
          "WORMHOLE_STRUCTURE_PANEL_TIMEOUT_SECONDS": "95"
        },
        "review": {
          "WORMHOLE_STRUCTURE_QUALITY": "review",
          "WORMHOLE_STRUCTURE_PANEL_TIMEOUT_SECONDS": "120"
        },
        "full": {
          "WORMHOLE_STRUCTURE_QUALITY": "full",
          "WORMHOLE_STRUCTURE_PANEL_TIMEOUT_SECONDS": "190"
        }
      },
      "allowedOverlayModes": [
        "none",
        "dual_reality_straight_vs_curved",
        "step_budget_heatmap",
        "domain_ownership_map"
      ],
      "allowedPlacements": [
        "none",
        "minimap_inset",
        "side_by_side",
        "contact_sheet_only"
      ],
      "overlayEnv": {
        "step_budget_heatmap": {
          "WORMHOLE_STRUCTURE_EXTRA_PANELS": "1"
        },
        "domain_ownership_map": {
          "WORMHOLE_STRUCTURE_EXTRA_PANELS": "1"
        }
      },
      "expectedReports": [
        "wormhole_structure_report.md"
      ],
      "expectedContactSheets": [
        "wormhole_structure_contact_sheet.png"
      ],
      "expectedSummaries": [
        "wormhole_structure_summary.json"
      ],
      "expectedPreviews": [
        "testbench_preview.png",
        "panels/clean_curved/clean_curved_film.png",
        "panels/straight_vs_curved/straight_vs_curved_composed.png",
        "panels/depth_heatmap/depth_heatmap_film.png",
        "panels/step_budget_heatmap/step_budget_heatmap_composed.png",
        "panels/domain_diagnostics/domain_diagnostics_film.domain_id.png",
        "panels/structure_minimap/structure_minimap_composed.png"
      ],
      "guardrailText": "Visual observatory only. Dual-reality and diagnostic overlays visualize renderer transport structure, not physical wormhole evidence or validation verdicts."
    },
