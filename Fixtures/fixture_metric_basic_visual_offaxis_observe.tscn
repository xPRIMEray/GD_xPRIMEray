[node name="FieldSource3D" type="Node3D" parent="."]
script = ExtResource("1_field")
TransportModel = 1
EffectiveEquationCore = "source=canonical
r=|p-c|
u=clamp((r-rInner)/max(eps,rOuter-rInner),0,1)
f(u)=(1-u)^1
edge_ramp=1 (disabled)"
EffectiveEquationIntegrated = "dir=-normalize(p-c) (ModeFlagInvertSign=0)
absorb_if_r_lt_rInner=0
beta_eff=(|beta_g|>eps ? beta_g*1 : 1)
mag=beta_eff*amp*f(u)*edge_ramp
gamma=1
a=dir*mag"

