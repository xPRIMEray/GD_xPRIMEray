[gd_scene load_steps=7 format=3 uid="uid://c4bnd1sh3l1ry"]

; Fixture: boundary shell entry-basic
; Purpose: minimal CrossingEvent/EntryOnly baseline.
;   One sphere shell (radius 3.5) centred at origin. Camera outside at Z=7.
;   BiasDirection=Up, BiasStrength=0.15 → ≈8.5° upward kink at entry surface.
;   No FieldSource3D; BendScale=0. Rays are straight lines; effect is isolated to crossing.
;   DebugLogCrossings=true → one "[BLV] entry event" per ray that enters the shell.
;
; Expected visual:
;   Backdrop and dots behind the shell appear shifted downward by ≈2.7 units at backdrop Z=-15.
;   (Ray aimed at centre-pixel enters shell, gets nudged up; hits backdrop above centre.)
;   Rays that miss the shell (outside the projected disc) are undistorted.
;   Sharp discontinuity at the projected shell rim.
;
; Start-inside check: camera is at Z=7 which is outside the radius-3.5 shell. No false entry.
; CrossingPolicy: EntryOnly (default=0). Exit crossing is detected but not dispatched.

[ext_resource type="Script" uid="uid://6p4s26slgv8l" path="res://BoundaryLayerVolume.cs" id="1_blv"]
[ext_resource type="Script" uid="uid://dg2asfleehqsw" path="res://RayBeamRenderer.cs" id="2_rbr"]

